@{
    ViewData["Title"] = "都道府県・市区町村選択";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold">ASP.NET Core MVC & Blazor</h1>
                <p class="lead text-muted">Blazor コンポーネントによる連動ドロップダウンのサンプルです。</p>
            </div>

            <div class="blazor-wrapper">
                <component type="typeof(AspNetCoreBlazorInMvc.Components.LocationSelector)" render-mode="ServerPrerendered" />
            </div>

            <div class="mt-5 text-center text-muted small">
                <p>
                    <i class="bi bi-info-circle me-1"></i>
                    このフォームは Blazor コンポーネント (SignalR) を使用して、C# のみで非同期通信と UI 更新を実現しています。
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .blazor-wrapper {
        border-radius: 1rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        background-color: #fff;
    }
</style>
