@code {
    private List<string> users = new() { "田中", "佐藤" };
    private string newUserName = "";

    private void AddUser()
    {
        if (!string.IsNullOrWhiteSpace(newUserName))
        {
            users.Add(newUserName);
            newUserName = "";
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddUser();
        }
    }
}

<div class="card p-3 shadow-sm border-0 bg-light rounded-3">
    <h4 class="mb-3 text-primary"><i class="bi bi-people-fill me-2"></i>ユーザー一覧 (Blazor)</h4>
    <div class="mb-3">
        <ul class="list-group list-group-flush mb-3 rounded-2 overflow-hidden shadow-sm">
            @foreach (var user in users)
            {
                <li class="list-group-item d-flex align-items-center">
                    <span class="badge bg-primary rounded-pill me-3">@user.Substring(0, 1)</span>
                    @user
                </li>
            }
        </ul>
    </div>
    
    <div class="input-group">
        <input @bind="newUserName" @bind:event="oninput" @onkeydown="HandleKeyDown" class="form-control" placeholder="新しい名前を入力" aria-label="New user name" />
        <button class="btn btn-primary" @onclick="AddUser">
            <i class="bi bi-person-plus-fill me-1"></i>追加
        </button>
    </div>
</div>
